# Product API
PRODUCTS_API_URL=https://pelasko-morvarid.ir/api/products
PRODUCT_BASE_URL=https://pelasko-morvarid.ir
PRODUCTS_API_TIMEOUT=60

# Embeddings & Search
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
DATA_DIR=data
SEARCH_TOP_K=5

# GapGPT (required for AI responses)
GAPGPT_API_KEY=
GAPGPT_MODEL=gapgpt-qwen-3.5
GAPGPT_BASE_URL=https://api.gapgpt.app/v1
GAPGPT_TIMEOUT=120

# Public URLs (change for production)
PUBLIC_HOST=localhost
PORT=8000
CLIENT_PORT=5173

# Optional — auto-built from PUBLIC_HOST if empty
API_URL=
CLIENT_URL=
CORS_ORIGINS=

# Client WebSocket (empty = auto-detect in browser)
VITE_WS_URL=

# Server
HOST=0.0.0.0
LOG_LEVEL=INFO

# Scheduled index rebuild
INDEX_REBUILD_ENABLED=true
INDEX_REBUILD_INTERVAL_HOURS=24

# Product API
PRODUCTS_API_URL=https://pelasko-morvarid.ir/api/products
PRODUCT_BASE_URL=https://pelasko-morvarid.ir
PRODUCTS_API_TIMEOUT=60

# Embeddings & Search
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
DATA_DIR=data
SEARCH_TOP_K=5

# GapGPT
GAPGPT_API_KEY=
GAPGPT_MODEL=gapgpt-qwen-3.5
GAPGPT_BASE_URL=https://api.gapgpt.app/v1
GAPGPT_TIMEOUT=120

# Public host and ports
# local:   API http://localhost:8000  |  Client http://localhost:5173  |  WS ws://localhost:5173/ws/chat
# server:  API http://185.128.139.65:8999  |  Client http://185.128.139.65:5199  |  WS ws://185.128.139.65:5199/ws/chat
PUBLIC_HOST=localhost
PORT=8000
CLIENT_PORT=5173

# Full URLs (optional, auto-built from PUBLIC_HOST if empty)
# API_URL=http://localhost:8000
# CLIENT_URL=http://localhost:5173
API_URL=
CLIENT_URL=

# CORS (optional, must include port; auto from CLIENT_URL if empty)
# CORS_ORIGINS=http://localhost:5173
# CORS_ORIGINS=http://185.128.139.65:5199
CORS_ORIGINS=

# WebSocket for client build (optional, leave empty for auto-detect)
# VITE_WS_URL=ws://localhost:5173/ws/chat
# VITE_WS_URL=ws://185.128.139.65:5199/ws/chat
VITE_WS_URL=

# Server
HOST=0.0.0.0
LOG_LEVEL=INFO

# Index rebuild every 24 hours
INDEX_REBUILD_ENABLED=true
INDEX_REBUILD_INTERVAL_HOURS=24
